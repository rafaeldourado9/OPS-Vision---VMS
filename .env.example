# ── Django ──────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# ── Database ────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vms
POSTGRES_USER=vms
POSTGRES_PASSWORD=change-me

# ── Redis ───────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=vms
RABBITMQ_PASSWORD=change-me

# ── MediaMTX ────────────────────────────────
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_STREAM_BASE_URL=http://mediamtx:8889
# URLs públicas acessíveis pelo browser (ajuste para IP/domínio do servidor)
MEDIAMTX_HLS_BASE_URL=http://localhost:8888
MEDIAMTX_WEBRTC_BASE_URL=http://localhost:8889
# ── Stream Tokens ────────────────────────────
STREAM_TOKEN_TTL_SECONDS=1800  # 30 minutos

# ── Recordings ──────────────────────────────
RECORDINGS_PATH=/data/recordings

# ── Storage Quota ────────────────────────────
STORAGE_QUOTA_BYTES_PER_TENANT=107374182400  # 100 GB por tenant
STORAGE_QUOTA_WARN_THRESHOLD=0.8             # Warning aos 80%

# ── Auth ────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── CORS ────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost

# ── Frontend ────────────────────────────────
VITE_API_BASE_URL=/api/v1
VITE_SSE_URL=/sse/
VITE_HLS_BASE_URL=http://localhost:8888
VITE_WEBRTC_BASE_URL=http://localhost:8889

# ── Celery Beat Schedules (segundos) ────────
CAMERA_HEALTH_CHECK_INTERVAL=300     # 5 min — verifica status online de câmeras
STORAGE_QUOTA_CHECK_INTERVAL=3600    # 1 h  — alerta de cota de storage
RECORDINGS_CLEANUP_INTERVAL=3600     # 1 h  — limpeza de segmentos expirados

# ── Internal Service URLs (entre containers) ─
DJANGO_INTERNAL_URL=http://django:8000

# ── Frontend ────────────────────────────────
# Dev (fora do Docker / acesso direto ao Django):
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SSE_URL=http://localhost:8001/sse/
# Produção (via nginx na porta 80):
# NEXT_PUBLIC_API_URL=http://localhost/api/v1
# NEXT_PUBLIC_SSE_URL=http://localhost/sse/
