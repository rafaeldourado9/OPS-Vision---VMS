FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    libgl1 libglib2.0-0 libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY yolo_worker/requirements.txt .
RUN pip install --upgrade pip && \
    for i in 1 2 3 4 5; do \
        pip install --retries 10 --timeout 600 -r requirements.txt && break || sleep 15; \
    done && \
    rm -rf /root/.cache/pip

COPY yolo_worker/worker/ ./worker/
COPY common/ ./common/

CMD ["python", "-m", "worker"]
